# GD32-Web-MaxClaw 后端配置
# ------------------------------

# 1. 环控器设备 IP 地址 (修改此处后重启后端生效)
DEVICE_IP=192.168.10.110

# 2. 电脑本地 IP 地址 (用于解决多网卡抓错 IP 问题)
LOCAL_IP=192.168.10.123

# 3. 后端 API 服务端口
PORT=3001

# 4. 固件存放路径
FIRMWARE_PATH=F:/firmware

# 5. 传感器模拟器 RS485 串口配置
SENSOR_SIM_PORT=COM8
SENSOR_SIM_BAUD=9600
